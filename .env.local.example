# TMDB Keys
TMDB_API_KEY=your_tmdb_api_key_here
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here
TMDB_API_TOKEN=your_tmdb_bearer_token_here

# MongoDB (Local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/cinephiles

# AI Configuration
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# OMDB Key (for extra ratings)
OMDB_API_KEY=your_omdb_api_key_here

# Trakt Configuration (Server-side only)
TRAKT_CLIENT_ID=your_trakt_client_id_here
TRAKT_CLIENT_SECRET=your_trakt_client_secret_here

# Streaming Provider
NEXT_PUBLIC_STREAM_URL=https://www.playimdb.com/title/
